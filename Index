<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Lesedi Edge — School Pilot Application | UmkhoAI</title>
<style>
  :root {
    --red: #C8102E;
    --red-dark: #9E0B23;
    --ink: #1A1A1A;
    --paper: #FFFFFF;
    --mist: #F7F5F3;
    --line: #E5E0DC;
    --muted: #6B6661;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--mist);
    color: var(--ink);
    font-family: 'Helvetica Neue', Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .topbar {
    background: var(--ink);
    color: var(--paper);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .topbar .mark {
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .topbar .mark span { color: var(--red); }

  .hero {
    background: var(--red);
    color: var(--paper);
    padding: 56px 24px 64px;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -60px;
    top: -60px;
    width: 240px;
    height: 240px;
    border: 2px solid rgba(255,255,255,0.18);
    border-radius: 50%;
  }

  .hero::before {
    content: "";
    position: absolute;
    right: 40px;
    bottom: -80px;
    width: 160px;
    height: 160px;
    border: 2px solid rgba(255,255,255,0.12);
    border-radius: 50%;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: 14px;
    font-weight: 600;
  }

  .hero h1 {
    font-size: clamp(28px, 5vw, 42px);
    line-height: 1.15;
    margin: 0 0 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .hero p {
    font-size: 16px;
    line-height: 1.6;
    max-width: 540px;
    opacity: 0.95;
    margin: 0 0 8px;
  }

  .hero .cities {
    margin-top: 24px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .city-pill {
    border: 1.5px solid rgba(255,255,255,0.5);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .container {
    max-width: 720px;
    margin: -32px auto 64px;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  form {
    background: var(--paper);
    border-radius: 4px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    padding: 40px;
  }

  .section-title {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 6px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--ink);
  }

  .section-sub {
    font-size: 13px;
    color: var(--muted);
    margin: 8px 0 24px;
  }

  .section + .section {
    margin-top: 40px;
  }

  .field {
    margin-bottom: 18px;
  }

  .field label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--ink);
  }

  .field .hint {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 600px) {
    .row { grid-template-columns: 1fr; }
    form { padding: 28px 20px; }
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  input[type="number"],
  textarea,
  select {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid var(--line);
    border-radius: 3px;
    font-size: 15px;
    font-family: inherit;
    color: var(--ink);
    background: var(--paper);
    transition: border-color 0.15s ease;
  }

  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: var(--red);
  }

  textarea { resize: vertical; min-height: 70px; }

  .lang-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 4px;
  }

  @media (max-width: 600px) {
    .lang-grid { grid-template-columns: 1fr; }
  }

  .check-option {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1.5px solid var(--line);
    border-radius: 3px;
    padding: 10px 12px;
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .check-option:hover {
    border-color: var(--red);
    background: #FFF7F8;
  }

  .check-option input {
    width: auto;
    margin: 0;
    accent-color: var(--red);
  }

  .city-options {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .city-radio {
    flex: 1;
    min-width: 140px;
  }

  .city-radio input {
    display: none;
  }

  .city-radio label {
    display: block;
    text-align: center;
    border: 1.5px solid var(--line);
    border-radius: 3px;
    padding: 14px 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s ease;
    margin: 0;
  }

  .city-radio input:checked + label {
    border-color: var(--red);
    background: var(--red);
    color: var(--paper);
  }

  .city-radio label:hover {
    border-color: var(--red);
  }

  .submit-row {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  button[type="submit"] {
    width: 100%;
    background: var(--red);
    color: var(--paper);
    border: none;
    padding: 16px;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  button[type="submit"]:hover {
    background: var(--red-dark);
  }

  .fine-print {
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    margin-top: 14px;
    line-height: 1.6;
  }

  .footer-note {
    text-align: center;
    font-size: 12px;
    color: var(--muted);
    margin-top: 28px;
    letter-spacing: 0.05em;
  }

  .footer-note .accent { color: var(--red); font-weight: 800; }

  /* Success state */
  .success-screen {
    display: none;
    background: var(--paper);
    border-radius: 4px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    padding: 60px 40px;
    text-align: center;
  }

  .success-screen.visible { display: block; }

  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--red);
    color: var(--paper);
    font-size: 26px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .success-screen h2 {
    margin: 0 0 10px;
    font-size: 24px;
  }

  .success-screen p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    max-width: 420px;
    margin: 0 auto;
  }
</style>
</head>
<body>

  <div class="topbar">
    <div class="mark">Umkho<span>AI</span></div>
    <div>Lesedi Edge Pilot</div>
  </div>

  <div class="hero">
    <div class="hero-inner">
      <div class="eyebrow">School Pilot Application</div>
      <h1>Bring offline AI learning to your school — free.</h1>
      <p>The first yes opened the door. Now we're expanding Lesedi Edge to schools in Durban, Cape Town and Bloemfontein. No internet required — students learn across subjects using on-device AI, in the languages they already learn in.</p>
      <p>Apply on behalf of your school, or nominate one you know.</p>
      <div class="cities">
        <div class="city-pill">Durban</div>
        <div class="city-pill">Cape Town</div>
        <div class="city-pill">Bloemfontein</div>
      </div>
    </div>
  </div>

  <div class="container">

    <form id="pilotForm" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">

      <input type="hidden" name="_subject" value="New Lesedi Edge School Pilot Application" />

      <div class="section">
        <div class="section-title">Your details</div>
        <div class="section-sub">The person applying on behalf of the school.</div>

        <div class="field">
          <label for="applicant_name">Full name</label>
          <input type="text" id="applicant_name" name="Applicant Name" required />
        </div>

        <div class="row">
          <div class="field">
            <label for="applicant_phone">Phone number</label>
            <input type="tel" id="applicant_phone" name="Applicant Phone" required />
          </div>
          <div class="field">
            <label for="applicant_email">Email address</label>
            <input type="email" id="applicant_email" name="Applicant Email" required />
          </div>
        </div>

        <div class="field">
          <label for="applicant_role">Your role / relationship to the school</label>
          <input type="text" id="applicant_role" name="Applicant Role" placeholder="e.g. Parent, Teacher, SGB member, Principal" required />
          <div class="hint">Tell us how you're connected to this school.</div>
        </div>
      </div>

      <div class="section">
        <div class="section-title">School details</div>
        <div class="section-sub">Contact for the school, or a School Governing Body (SGB) member.</div>

        <div class="field">
          <label for="school_name">School name</label>
          <input type="text" id="school_name" name="School Name" required />
        </div>

        <div class="field">
          <label for="school_contact_name">School / SGB contact name</label>
          <input type="text" id="school_contact_name" name="School Contact Name" required />
        </div>

        <div class="row">
          <div class="field">
            <label for="school_phone">School contact phone</label>
            <input type="tel" id="school_phone" name="School Contact Phone" required />
          </div>
          <div class="field">
            <label for="school_email">School contact email</label>
            <input type="email" id="school_email" name="School Contact Email" required />
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Pilot location</div>
        <div class="section-sub">Which city is the school in?</div>

        <div class="city-options">
          <div class="city-radio">
            <input type="radio" id="city_durban" name="City" value="Durban" required />
            <label for="city_durban">Durban</label>
          </div>
          <div class="city-radio">
            <input type="radio" id="city_capetown" name="City" value="Cape Town" required />
            <label for="city_capetown">Cape Town</label>
          </div>
          <div class="city-radio">
            <input type="radio" id="city_bloem" name="City" value="Bloemfontein" required />
            <label for="city_bloem">Bloemfontein</label>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Classroom details</div>
        <div class="section-sub">Helps us prepare Lesedi Edge for your students.</div>

        <div class="field">
          <label for="student_count">Approximate number of students</label>
          <input type="number" id="student_count" name="Number of Students" min="1" required />
        </div>

        <div class="field">
          <label>Languages students are currently taught in</label>
          <div class="lang-grid">
            <label class="check-option"><input type="checkbox" name="Languages" value="English" /> English</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Afrikaans" /> Afrikaans</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="isiZulu" /> isiZulu</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="isiXhosa" /> isiXhosa</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Setswana" /> Setswana</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Sesotho" /> Sesotho</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Sepedi" /> Sepedi</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="isiNdebele" /> isiNdebele</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Siswati" /> Siswati</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Tshivenda" /> Tshivenda</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Xitsonga" /> Xitsonga</label>
            <label class="check-option"><input type="checkbox" name="Languages" value="Other" /> Other</label>
          </div>
        </div>

        <div class="field">
          <label for="extra_info">Anything else we should know?</label>
          <textarea id="extra_info" name="Additional Info" placeholder="Optional — subjects of interest, current device access, internet connectivity, etc."></textarea>
        </div>
      </div>

      <div class="submit-row">
        <button type="submit">Submit application</button>
        <div class="fine-print">UmkhoAI will review applications and reach out to shortlisted schools directly. Pilot participation is free of charge.</div>
      </div>

    </form>

    <div class="success-screen" id="successScreen">
      <div class="success-icon">✓</div>
      <h2>Application received</h2>
      <p>Thank you for nominating a school for the Lesedi Edge pilot. UmkhoAI's team will be in touch with next steps.</p>
    </div>

    <div class="footer-note">Lesedi Edge by <span class="accent">UmkhoAI</span> — Africa's offline AI ecosystem</div>

  </div>

  <script>
    const form = document.getElementById('pilotForm');
    const success = document.getElementById('successScreen');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          form.style.display = 'none';
          success.classList.add('visible');
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit application';
          alert('Something went wrong. Please try again.');
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit application';
        alert('Something went wrong. Please check your connection and try again.');
      }
    });
  </script>

</body>
</html>
